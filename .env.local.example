OPENAI_API_KEY=sk-...
# Optional tier-specific text model overrides.
# Free defaults to gpt-5.4-mini. Pro defaults to gpt-5.5.
OPENAI_FREE_MODEL=gpt-5.4-mini
OPENAI_PRO_MODEL=gpt-5.5
# Legacy fallback for the Pro tier.
OPENAI_MODEL=gpt-5.5
# Model used for AI front covers.
OPENAI_IMAGE_MODEL=gpt-image-2

# Neon Postgres. Vercel Marketplace injects DATABASE_URL automatically.
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Vercel Blob. Vercel Blob injects BLOB_READ_WRITE_TOKEN automatically.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
