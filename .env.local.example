OPENAI_API_KEY=sk-...
# OpenAI project ID (Settings → your project) so requests bill to that project, not the org default.
# OPENAI_PROJECT_ID=proj_...
# Required for unauthenticated cron/external worker calls to /api/jobs/run.
# Browser calls from signed-in users only process that user's queued jobs.
# JOB_RUNNER_SECRET=replace-with-a-long-random-value
# Comma-separated emails that should be provisioned as Pro without Stripe.
# Useful for owner/beta accounts before billing launches.
# FOLIO_OWNER_EMAILS=you@example.com

# Optional tier-specific text model overrides.
# Free defaults to gpt-5.4-mini. Pro defaults to gpt-5.5.
OPENAI_FREE_MODEL=gpt-5.4-mini
OPENAI_PRO_MODEL=gpt-5.5
# Legacy fallback for the Pro tier.
OPENAI_MODEL=gpt-5.5
# Model used for AI front covers.
OPENAI_IMAGE_MODEL=gpt-image-2

# Neon Postgres. Vercel Marketplace injects DATABASE_URL automatically.
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Vercel Blob. Vercel Blob injects BLOB_READ_WRITE_TOKEN automatically.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional Notion mirror for generated books.
# Use an internal integration token with access to the Folio Book Projects database.
NOTION_API_KEY=secret_...
NOTION_BOOKS_DATABASE_ID=08d8fb40c86d4420b2196876e4baa6a5

# Stripe Billing foundation. Leave unset until you are ready to test Checkout.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
